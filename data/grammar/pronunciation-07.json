    {
        "id": -149,
        "title": "[收尾音] ㄱ (舌根閉鎖音 / 斷路器)",
        "part": 0,
        "grammarRule": {
            "meaning": "最徹底的氣流阻斷。發音位置在舌頭後方與軟顎的接觸點。",
