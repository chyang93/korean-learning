            { "ko": "바쁘다", "zh": "[ㄆㄚ-ㄅㄜ-ㄉㄚ] 忙碌 (平音+緊音)" },
            { "ko": "나비", "zh": "[ㄋㄚ-ㄅㄧ] 蝴蝶 (平音)" }
