{
    "id": 2,
    "title": "#2 아닙니다",
    "part": 1,
    "introDialogue": {
        "A": "일본 사람입니까?",
        "A_zh": "你是日本人嗎？",
        "B": "아니요, 일본 사람이 아닙니다.",
        "B_zh": "不，我不是日本人。",
        "vocabBreakdown": [
            {
                "ko": "일본",
                "zh": "日本"
            },
            {
                "ko": "사람",
                "zh": "人"
            },
            {
                "ko": "아니요",
                "zh": "不 / 不是"
            }
        ]
    },
    "grammarRule": {
        "explanation": "名詞的正式否定形式，相當於中文的「不是...」。",
        "note": "必須與主語助詞「이/가」連用。名詞有收音接 이，無收音接 가。",
        "detailedInstruction": [
            "1. 定義：這是 입니다 的否定形式，用於正式場合。",
            "2. 結構：[名詞] + 이/가 아닙니다。",
            "3. 助詞選擇：有收音 (batchim) 接『이』，無收音接『가』。",
            "4. 空格注意：助詞與 아닙니다 之間『必須留空格』。"
        ]
    },
    "examples": [
        {
            "ko": "저는 가수가 아닙니다.",
            "zh": "我不是歌手。"
        },
