[
    {
        "id": -200,
        "title": "[基本母音] ㅏ (ㄚ)",
        "part": 0,
        "grammarRule": {
            "explanation": "韓文最基礎的母音。注意：因為母音不能單獨出現，所以加上不發音的『ㅇ』組成『아』，『ㅇ』在字首時「不發音」，僅作為母音的載體。",
            "note": "口型要領：嘴巴自然張大，發音同注音「ㄚ」。",
            "detailedInstruction": [
                "1. 注音符號：ㄚ",
                "2. 口型：嘴巴縱向張開，類似看牙醫時受檢的感覺。",
                "3. 氣量：穩定輸出。"
            ]
        },
        "examples": [
            {
                "ko": "아",
                "zh": "[ㄚ]"
            }
        ]
    },
    {
        "id": -199,
        "title": "[基本母音] ㅑ (ㄧㄚ)",
        "part": 0,
        "grammarRule": {
            "explanation": "由『ㅣ (ㄧ)』快速滑向『ㅏ (ㄚ)』的衍生音。",
            "note": "口型要領：起點是半閉的『ㄧ』，終點是全開的『ㄚ』。",
            "detailedInstruction": [
                "1. 注音符號：ㄧㄚ",
                "2. 組合形式：加上不發音的『ㅇ』組成『야』。",
                "3. 技巧：滑動過程要流暢，結尾口型要張大。"
            ]
        },
        "examples": [
            {
                "ko": "야",
                "zh": "[ㄧㄚ]"
            }
        ]
    },
    {
        "id": -198,
        "title": "[基本母音] ㅓ (ㄛ - 大張口)",
        "part": 0,
        "grammarRule": {
            "explanation": "嘴巴張開度比中文『ㄛ』大的大張口音。",
            "note": "口型要領：下巴向下掉，嘴角放鬆不出力，呈現橢圓形。",
            "detailedInstruction": [
                "1. 注音符號：ㄛ (大張口)",
                "2. 組合形式：加上不發音的『ㅇ』組成『어』。",
                "3. 注意：關鍵在於「不圓唇」，嘴唇不能縮成圓形。"
            ]
        },
        "examples": [
            {
                "ko": "어",
                "zh": "[ㄛ]"
            }
        ]
    },
    {
        "id": -197,
        "title": "[基本母音] ㅕ (ㄧㄛ - 大張口)",
        "part": 0,
        "grammarRule": {
            "explanation": "由『ㅣ (ㄧ)』滑向大張口的『ㅓ (ㄛ)』。",
            "note": "口型要領：從扁平口型迅速掉下巴，維持不圓唇狀態。",
            "detailedInstruction": [
                "1. 注音符號：ㄧㄛ (大張口)",
                "2. 組合形式：加上不發音的『ㅇ』組成『여』。",
                "3. 氣量：連續流暢。"
            ]
        },
        "examples": [
            {
                "ko": "여",
                "zh": "[ㄧㄛ]"
            }
        ]
    },
    {
        "id": -196,
        "title": "[基本母音] ㅗ (ㄡ - 圓唇音)",
        "part": 0,
        "grammarRule": {
            "explanation": "韓文的圓唇音。發音時嘴唇要縮得非常圓。",
            "note": "口型要領：嘴唇用力向前凸，形成一個清晰的小圓圈。",
            "detailedInstruction": [
                "1. 注音符號：ㄡ (圓唇)",
                "2. 組合形式：加上不發音的『ㅇ』組成『오』。",
                "3. 注意：發音重點在於「圓唇」，嘴巴張開度很小。"
            ]
        },
        "examples": [
            {
                "ko": "오",
                "zh": "[ㄡ]"
            }
        ]
    },
    {
        "id": -195,
        "title": "[基本母音] ㅛ (ㄧㄡ - 圓唇音)",
        "part": 0,
        "grammarRule": {
            "explanation": "由『ㅣ (ㄧ)』滑向圓唇的『ㅗ (ㄡ)』。",
            "note": "口型要領：嘴角迅速聚攏成小圓，類似英文的『Yo』。",
            "detailedInstruction": [
                "1. 注音符號：ㄧㄡ (圓唇)",
                "2. 組合形式：加上不發音的『ㅇ』組成『요』。",
                "3. 技巧：結束時嘴唇必須呈現圓形。"
            ]
        },
        "examples": [
            {
                "ko": "요",
                "zh": "[ㄧㄡ]"
            }
        ]
    },
    {
        "id": -194,
        "title": "[基本母音] ㅜ (ㄨ)",
        "part": 0,
        "grammarRule": {
            "explanation": "標準的『ㄨ』音，嘴唇用力向前凸起。",
            "note": "口型要領：嘴唇比『ㅗ』更向外突出，圓孔更小。",
            "detailedInstruction": [
                "1. 注音符號：ㄨ",
                "2. 組合形式：加上不發音的『ㅇ』組成『우』。",
                "3. 氣量：集中且平緩。"
            ]
        },
        "examples": [
            {
                "ko": "우",
                "zh": "[ㄨ]"
            }
        ]
    },
    {
        "id": -193,
        "title": "[基本母音] ㅠ (ㄧㄨ)",
        "part": 0,
        "grammarRule": {
            "explanation": "由『ㅣ (ㄧ)』滑向『ㅜ (ㄨ)』，類似英文的『You』。",
            "note": "口型要領：從扁平口型迅速轉變為向外凸出的極小圓孔。",
            "detailedInstruction": [
                "1. 注音符號：ㄧㄨ",
                "2. 組合形式：加上不發音的『ㅇ』組成『유』。",
                "3. 技巧：結尾嘴唇一定要向前嘟起。"
            ]
        },
        "examples": [
            {
                "ko": "유",
                "zh": "[ㄧㄨ]"
            }
        ]
    },
    {
        "id": -192,
        "title": "[基本母音] ㅡ (ㄜ - 扁平音)",
        "part": 0,
        "grammarRule": {
            "explanation": "韓文最具特色的扁平音。",
            "note": "口型要領：嘴角拉到最平，類似咬牙切齒或尷尬微笑。",
            "detailedInstruction": [
                "1. 注音符號：ㄜ (扁平音)",
                "2. 組合形式：加上不發音的『ㅇ』組成『으』。",
                "3. 注意：不可帶有圓唇感，嘴角必須向外扯。"
            ]
        },
        "examples": [
            {
                "ko": "으",
                "zh": "[ㄜ]"
            }
        ]
    },
    {
        "id": -191,
        "title": "[基本母音] ㅣ (ㄧ)",
        "part": 0,
        "grammarRule": {
            "explanation": "標準的『ㄧ』音，與注音發音一致。",
            "note": "口型要領：嘴角向兩側拉開，舌尖抵住下齒背。",
            "detailedInstruction": [
                "1. 注音符號：ㄧ",
                "2. 組合形式：加上不發音的『ㅇ』組成『이』。",
                "3. 特色：這是韓文中最尖銳、發音位置最高的母音。"
            ]
        },
        "examples": [
            {
                "ko": "이",
                "zh": "[ㄧ]"
            }
        ]
    },
