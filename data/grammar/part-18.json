{
    "id": 18,
    "title": "#18 아요 / 어요 / 해요",
    "part": 5,
    "introDialogue": {
        "A": "지금 뭐 해요?",
        "A_zh": "現在在做什麼？",
        "B": "밥을 먹어요.",
        "B_zh": "在吃飯。",
        "vocabBreakdown": [
            {
                "ko": "지금",
                "zh": "現在"
            },
            {
                "ko": "뭐",
                "zh": "什麼"
            },
            {
                "ko": "밥",
                "zh": "飯"
            }
        ]
    },
    "grammarRule": {
        "explanation": "動詞或形容詞的現在式終結詞尾，表示當前的動作或狀態。",
        "note": "根據詞幹的最後一個母音進行三種變化。",
        "detailedInstruction": [
            "1. 아요：詞幹母音為『ㅏ』或『ㅗ』時使用。",
            "2. 어요：詞幹母音不是『ㅏ, ㅗ』的所有其他情況使用。",
            "3. 해요：所有以『하다』結尾的動詞（如 공부하다）一律改為해요。",
            "4. 縮略現象：若詞幹本身無收音，母音會與詞尾發生縮略（如 가다 + 아요 -> 가요）。"
        ]
    },
    "examples": [
        {
            "ko": "저는 학교에 가요.",
            "zh": "我去學校。"
        },
        {
            "ko": "사과가 맛있어요.",
            "zh": "蘋果很好吃。"
        },
