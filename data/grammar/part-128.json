[
    {
        "id": -119,
        "title": "[助詞對比] 이/가 vs 은/는",
        "part": 0,
        "introDialogue": {
            "A": "누가 민수 씨입니까?",
            "A_zh": "誰是民秀先生？（強調『誰』）",
            "B": "제가 민수입니다. 저는 학생입니다.",
            "B_zh": "我才是民秀。我（至於我）是學生。",
            "vocabBreakdown": [
                {
                    "ko": "누구 (누가)",
                    "zh": "誰"
                },
                {
                    "ko": "제 (제가)",
                    "zh": "我 (主格)"
                },
                {
                    "ko": "저 (저는)",
                    "zh": "我 (主題)"
                }
            ]
        },
        "grammarRule": {
            "meaning": "區分句子中的『主語（執行者）』與『主題（討論對象）』。",
            "pattern": "【이/가】有收音 + 이 / 無收音 + 가 \n【은/는】有收音 + 은 / 無收音 + 는",
            "detailedInstruction": [
                "1. 焦點差異：이/가 強調前面的『主詞（是誰）』；은/는 強調後面的『敘述（是什麼樣）』。",
                "2. 資訊類型：이/가 用於引進『新資訊』；은/는 用於提到『舊資訊』或『常理』。",
                "3. 對比功能：은/稱 具有強烈的對比意涵（如：蘋果甜，但橘子酸）。",
                "4. 固定搭配：在『있습니다/없습니다』與『아닙니다』句型中，前面習慣接 이/가。"
            ]
        },
        "examples": [
            {
                "ko": "비가 옵니다.",
                "zh": "【이/가】下雨了。（引進新發現的狀況）"
            },
            {
                "ko": "가방이 무겁습니다.",
                "zh": "【이/가】書包很重。（強調是『書包』重）"
            },
            {
                "ko": "A: 누가 요리사입니까? \nB: 제가 요리사입니다.",
                "zh": "【이/가】A: 誰是廚師？ B: 我（才是）廚師。"
            },
            {
                "ko": "저는 대만 사람입니다.",
                "zh": "【은/는】我是台灣人。（自我介紹主題）"
            },
            {
                "ko": "동생은 작습니다. 형은 큽니다.",
                "zh": "【은/는】弟弟很矮，（對比）哥哥很高。"
            },
