    {
        "id": -189,
        "title": "[複合母音] ㅐ (ㄝ - 大張口)",
        "part": 0,
        "grammarRule": {
            "explanation": "由「ㅏ」與「ㅣ」組合而成。",
            "note": "口型要領：嘴巴張開度較大。",
            "detailedInstruction": [
                "1. 注音符號：ㄝ (大張口)",
                "2. 組合形式：加上不發音的『ㅇ』組成『애』。",
                "3. 技巧：舌尖抵住下齒背，嘴角用力向兩邊拉開。"
            ]
        },
        "examples": [
            {
                "ko": "애",
                "zh": "[ㄝ]"
            }
        ]
    },
    {
        "id": -188,
        "title": "[複合母音] ㅒ (ㄧㄝ - 大張口)",
        "part": 0,
        "grammarRule": {
            "explanation": "「ㄧ」滑向「ㅐ」。發音類似注音的「ㄧㄝ」。",
            "note": "口型要領：從「ㄧ」出發，迅速張大口發「ㄝ」。",
            "detailedInstruction": [
                "1. 注音符號：ㄧㄝ",
                "2. 組合形式：加上不發音的『ㅇ』組成『얘』。",
                "3. 注意：在現代韓語中，主要見於代名詞或特定單字。"
            ]
        },
        "examples": [
            {
                "ko": "얘",
                "zh": "[ㄧㄝ]"
            }
        ]
    },
    {
        "id": -187,
        "title": "[複合母音] ㅔ (ㄝ - 小張口)",
        "part": 0,
        "grammarRule": {
            "explanation": "由「ㅓ」與「ㅣ」組合而成。發音類似注音的「ㄝ」。",
            "note": "口型要領：嘴巴張開度較小，類似微笑時的寬度。",
            "detailedInstruction": [
                "1. 注音符號：ㄝ (小張口)",
                "2. 組合形式：加上不發音的『ㅇ』組成『에』。",
                "3. 辨析：在現代口語中與『ㅐ』幾乎無區別，可視為同音。"
            ]
        },
        "examples": [
            {
                "ko": "에",
                "zh": "[ㄝ]"
            }
