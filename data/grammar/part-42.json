{
    "id": 42,
    "title": "#42 [名詞] 전 / [動詞]-기 전에",
    "part": 11,
    "introDialogue": {
        "A": "언제 운동을 합니까?",
        "A_zh": "什麼時候運動？",
        "B": "저녁을 먹기 전에 운동을 합니다.",
        "B_zh": "吃飯前運動。",
        "vocabBreakdown": [
            {
                "ko": "언제",
                "zh": "什麼時候"
            },
            {
                "ko": "저녁",
                "zh": "晚餐 / 晚上"
            },
            {
                "ko": "식사",
                "zh": "用餐"
            }
        ]
    },
    "grammarRule": {
        "explanation": "表示在某個時間點或動作發生之前。",
        "note": "名詞直接接 전；動詞需先名詞化改為 -기 形式。",
        "detailedInstruction": [
            "1. 名詞 + 전：例如：한 시간 전 (一小時前)、수업 전 (課前)。",
            "2. 動詞詞幹 + 기 전에：例如：가기 전에 (去之前)、먹기 전에 (吃之前)。",
            "3. 特點：無論動詞有無收音，一律使用『-기 전에』。",
            "4. 語序：放在句子中間作為時間背景。"
        ]
    },
    "examples": [
        {
            "ko": "식사 전에 손을 씻으세요.",
            "zh": "吃飯前請洗手。"
        },
        {
            "ko": "한국에 가기 전에 한국어를 공부합니다.",
            "zh": "去韓國之前學習韓語。"
        },
        {
            "ko": "잠을 자기 전에 주스를 마십니다.",
            "zh": "睡覺前喝果汁。"
        },
        {
            "ko": "수업 시작하기 전에 책을 읽으세요.",
            "zh": "上課開始前請看書。"
        },
        {
            "ko": "A: 언제 숙제를 했어요? \nB: 수업 전이요.",
            "zh": "A: 什麼時候做完作業的？\nB: 上課前。"
        },
