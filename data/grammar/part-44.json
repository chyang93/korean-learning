{
    "id": 44,
    "title": "#44 [動詞/形容詞]-지만",
    "part": 12,
    "introDialogue": {
        "A": "이 음식이 맵습니까?",
        "A_zh": "這個食物辣嗎？",
        "B": "조금 맵지만 맛있습니다.",
        "B_zh": "雖然有點辣，但很好吃。",
        "vocabBreakdown": [
            {
                "ko": "음식",
                "zh": "食物"
            },
            {
                "ko": "맵다",
                "zh": "辣"
            },
            {
                "ko": "맛있다",
                "zh": "好吃"
            }
        ]
    },
    "grammarRule": {
        "explanation": "連接兩個語意相反或對立的句子，表示『但是』、『雖然...但是』。",
        "note": "詞幹直接接 -지만，不分有無收音。",
        "detailedInstruction": [
            "1. 結構：[句子A 詞幹]-지만 + [句子B]。",
            "2. 時態：過去式可接 -았/었지만。例如：갔지만 (雖然去了)。",
            "3. 特點：用於連接同一個句子中的兩個子句。"
        ]
    },
    "examples": [
        {
            "ko": "한국어 공부가 어렵지만 재미있습니다.",
            "zh": "韓語學習雖然難但很有趣。"
        },
        {
            "ko": "가방이 비싸지만 좋습니다.",
            "zh": "包包雖然貴但很好。"
        },
        {
            "ko": "키가 작지만 농구를 잘합니다.",
            "zh": "雖然個子小但籃球打得很棒。"
        },
        {
            "ko": "어제는 바빴지만 오늘은 안 바쁩니다.",
            "zh": "昨天雖然忙，但今天不忙。"
        },
        {
            "ko": "A: 백화점에 사람이 많습니까? \nB: 사람은 많지만 물건이 좋습니다.",
            "zh": "A: 百貨公司人多嗎？\nB: 雖然人多，但東西很好。"
        },
