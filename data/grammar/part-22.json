    "title": "#22 固有詞數字 (用於小時、年齡、數量)",
    "part": 6,
    "introDialogue": {
        "A": "몇 살입니까?",
        "A_zh": "幾歲呢？",
        "B": "스물네 살입니다.",
        "B_zh": "二十四歲。",
        "vocabBreakdown": [
            {
                "ko": "몇",
                "zh": "幾"
