    {
        "id": -177,
        "title": "[基本子音] ㄱ (ㄎ/ㄍ - 邏輯閘)",
        "part": 0,
        "grammarRule": {
            "meaning": "發音位置在舌根。會隨位置改變氣流輸出。",
            "pattern": "首字 [ㄎ] / 中間 [ㄍ]",
            "detailedInstruction": [
                "1. 若位置在首字：注音 ㄎ。輕微噴氣。",
                "2. 若位置在中字，不在首字：注音 ㄍ。不噴氣，發音較沉穩。",
                "3. 口型：舌根抬起抵住軟顎。",
                "4. 氣量：首字中等，中字極低。"
            ]
        },
        "examples": [
            {
                "ko": "고기",
                "zh": "肉 [首字:ㄎ / 中間:ㄍ][ㄎㄡ-ㄍㄧ]"
            },
            {
                "ko": "가구",
                "zh": "家具 [首字:ㄎ / 中間:ㄍ][ㄎㄚ-ㄍㄨ]"
            },
            {
                "ko": "가게",
                "zh": "商店 [首字:ㄎ / 中間:ㄍ][ㄎㄚ-ㄍㄟ]"
            },
            {
                "ko": "가수",
                "zh": "歌手 [首字:ㄎ][ㄎㄚ-ㄙㄨ]"
            },
            {
                "ko": "아기",
                "zh": "嬰兒 [中間:ㄍ][ㄚ-ㄍㄧ]"
            }
        ]
    },
