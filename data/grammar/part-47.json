{
    "id": 47,
    "title": "#47 [名詞](으)로",
    "part": 13,
    "introDialogue": {
        "A": "어떻게 학교에 가요?",
        "A_zh": "怎麼去學校？",
        "B": "버스로 가요. 오른쪽으로 가세요.",
        "B_zh": "搭公車去。請往右邊走。",
        "vocabBreakdown": [
            {
                "ko": "어떻게",
                "zh": "如何 / 怎麼"
            },
            {
                "ko": "버스",
                "zh": "公車"
            },
            {
                "ko": "오른쪽",
                "zh": "右邊"
            }
        ]
    },
    "grammarRule": {
        "explanation": "表示方向、工具、方法、身分或變化的多功能助詞。",
        "note": "根據名詞末尾有無收音決定形式，注意 ㄹ 收音不變形。",
        "detailedInstruction": [
            "1. 方向 (往)：오른쪽으로 (往右)、서울로 (往首爾)。",
            "2. 工具/方法 (用)：한국어로 (用韓語)、젓가락으로 (用筷子)。",
            "3. 交通工具 (搭乘)：기차로 (搭火車)、택시로 (搭計程車)。",
            "4. 選擇 (當/作為)：이것으로 (選這個)、선물로 (作為禮物)。",
            "5. 變化 (成)：물로 (變成水)。",
            "6. 形式：無收音或 ㄹ 收音接『로』；有收音接『으로』。"
        ]
    },
    "examples": [
        {
            "ko": "왼쪽으로 가세요.",
            "zh": "請往左邊走。"
        },
        {
