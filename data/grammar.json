    {
        "id":  1,
        "title":  "#1 입니까? / 입니다",
        "part":  1,
        "introDialogue":  {
                              "A":  "대만 사람입니까?",
                              "A_zh":  "你是台灣人嗎？",
                              "B":  "저는 대만 사람입니다.",
                              "B_zh":  "我是台灣人。",
                              "vocabBreakdown":  [
                                                     {
                                                         "ko":  "저",
                                                         "zh":  "我"
                                                     },
                                                     {
                                                         "ko":  "사람",
                                                         "zh":  "人"
                                                     },
                                                     {
                                                         "ko":  "대만",
                                                         "zh":  "台灣"
                                                     }
                                                 ]
                          },
        "grammarRule":  {
                            "explanation":  "名詞接尾語，用於正式場合的問句與陳述句。",
                            "note":  "無論名詞有無收音（받침），皆可接上 입니까? 或 입니다。"
                        },
        "examples":  [
                         {
                             "ko":  "저는 학생입니다.",
                             "zh":  "我是學生。"
                         },
                         {
                             "ko":  "한국어 선생님입니까?",
                             "zh":  "是韓文老師嗎？"
                         },
                         {
                             "ko":  "여기는 학교입니까?",
                             "zh":  "這裡是學校嗎？"
                         }
                     ],
        "relatedVocabIds":  [
                                "V001",
                                "V002",
                                "V003"
                            ]
    },
    {
        "id":  2,
