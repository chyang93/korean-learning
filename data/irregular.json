{
  "ㅂ": {
    "title": "ㅂ 不規則 (ㅂ 變 우/오)",
    "rule": "當詞幹末尾音節以 'ㅂ' 結尾，遇到元音（아/어）時，'ㅂ' 會變成 '우'。若是連接 -아요/어요，則變成 -워요。",
    "examples": [
      {
        "base": "춥다",
        "changed": "추워요",
        "zh": "冷 → 很冷",
        "note": "常用於天氣描述"
      },
      {
        "base": "맵다",
        "changed": "매워요",
        "zh": "辣 → 很辣",
        "note": "形容食物味道"
      },
      {
        "base": "돕다",
        "changed": "도와요",
        "zh": "幫助 → 幫助",
        "note": "⚠️ 特例：돕다/곱다 變化為 '오' 而非 '우'"
      }
    ]
  },
  "ㄹ": {
    "title": "ㄹ 脫落全攻略",
    "rule": "當詞幹末尾音節以 'ㄹ' 結尾，遇到 'ㄴ, ㅂ, ㅅ' 開頭的文法時，'ㄹ' 會脫落。",
    "examples": [
      {
        "base": "살다",
        "changed": "삽니다",
        "zh": "居住 (格式體)",
        "note": "遇到 ㅂ 結尾的語法時 ㄹ 消失"
      },
      {
        "base": "알다",
        "changed": "아세요",
        "zh": "知道 (敬語)",
        "note": "遇到 ㅅ 開頭的語法時 ㄹ 消失"
      },
      {
        "base": "만들다",
        "changed": "만듭니다",
        "zh": "做 → 做 (格式體)",
        "note": "製作的正式說法"
      }
    ]
  },
  "ㄷ": {
    "title": "ㄷ 不規則 (ㄷ -> ㄹ)",
    "rule": "當詞幹末尾音節以 'ㄷ' 結尾，遇到元音開頭的文法時，'ㄷ' 會變成 'ㄹ'。",
    "examples": [
      {
        "base": "듣다",
        "changed": "들어요",
        "zh": "聽 → 聽",
        "note": "最常見的 ㄷ 不規則"
      },
      {
        "base": "걷다",
        "changed": "걸어요",
        "zh": "走路 → 走路",
        "note": "注意：部分動詞如 닫다(關) 為規則變化"
      }
    ]
  },
  "ㅎ": {
    "title": "ㅎ 不規則 (ㅎ 脫落與母音融合)",
    "rule": "當詞幹末尾音節以 'ㅎ' 結尾，遇到元音開頭的文法時，'ㅎ' 脫落，且原本的元音會與後面合併（通常變成 애）。",
    "examples": [
      {
        "base": "빨갛다",
        "changed": "빨개요",
        "zh": "紅 → 紅色的",
        "note": "顏色詞多屬此類"
      },
      {
        "base": "어떻다",
        "changed": "어때요",
        "zh": "如何 → 怎麼樣",
        "note": "疑問詞常用型態"
      }
    ]
  },
  "르": {
    "title": "르 不規則 (르 脫落補 ㄹ)",
    "rule": "當詞幹末尾為 '르'，遇到元音時，'ㅡ' 脫落，前面的音節補上一個 'ㄹ'，後面則根據元音性質加上 '라/러'。",
    "examples": [
      {
        "base": "모르다",
        "changed": "몰라요",
        "zh": "不知道 → 不知道",
        "note": "日常最常用單字"
      },
      {
        "base": "다르다",
        "changed": "달라요",
        "zh": "不同 → 不同",
        "note": "形容詞用法"
      }
    ]
  },
  "ㅅ": {
    "title": "ㅅ 脫落全攻略 (脫落但不縮寫)",
    "rule": "當詞幹末尾音節以 'ㅅ' 結尾，遇到元音開頭的文法時，'ㅅ' 會脫落，但前後音節不進行合併（即不縮寫）。",
    "examples": [
      {
        "base": "낫다",
        "changed": "나아요",
        "zh": "好轉/痊癒 → 康復了",
        "note": "注意：웃다(笑) 為規則變化"
      },
      {
        "base": "짓다",
        "changed": "지어요",
        "zh": "蓋(房子)/取(名) → 蓋/取",
        "note": "常用於抽象或具體創造"
      }
    ]
  },
  "ㅡ": {
    "title": "ㅡ 脫落規則",
    "rule": "當詞幹末尾音節為 'ㅡ' 且為單音節或前面無其他元音時，遇到元音會直接脫落，並根據前面或本身的性質補上 '아/어'。",
    "examples": [
      {
        "base": "쓰다",
        "changed": "써요",
        "zh": "寫/用/苦 → 寫/用/苦",
        "note": "多義詞"
      },
      {
        "base": "바쁘다",
        "changed": "바빠요",
        "zh": "忙碌 → 很忙",
        "note": "依照前面的 'ㅏ' 補上 '아요'"
      }
    ]
  },
  "ㄴ_鼻音化": {
    "title": "ㄴ 添加 (初階：鼻音化連鎖)",
    "rule": "在複合詞中，若前一個詞以輔音結尾，後一個詞以 i, ya, yeo, yo, yu 開頭，會添加 'ㄴ' 音。若前一個輔音是塞音，會進一步引發鼻音化連鎖反應。",
    "examples": [
      {
        "base": "맨입",
        "changed": "[맨닙]",
        "zh": "空口/空腹",
        "note": "直接添加 ㄴ 音"
      },
      {
        "base": "솜이불",
        "changed": "[솜니불]",
        "zh": "棉被",
        "note": "ㅁ + 이 變為 [ㅁ+니]"
      },
      {
        "base": "꽃잎",
        "changed": "[꼰닙]",
        "zh": "花瓣",
        "note": "連鎖反應：꽃잎 -> 꼳닙 -> 꼰닙"
      }
    ]
  },
  "ㄴ_流音化": {
    "title": "ㄴ 添加 (進階：流音化結合)",
    "rule": "當 'ㄴ' 添加發生時，若前一個詞的尾音是 'ㄹ'，則添加的 'ㄴ' 會受到影響轉化為 'ㄹ'，產生流音化結合現象。",
    "examples": [
      {
        "base": "물약",
        "changed": "[물략]",
        "zh": "藥水",
        "note": "物(물) + 藥(약) -> [물냑] -> [물략]"
      },
      {
        "base": "서울역",
        "changed": "[서울력]",
        "zh": "首爾站",
        "note": "서울 + 역 -> [서울녁] -> [서울력]"
      },
      {
        "base": "들일",
        "changed": "[들릴]",
        "zh": "農活",
        "note": "들 + 일 -> [들닐] -> [들릴]"
      }
    ]
  }
}